<div class="modal fade"
     id="rename-cost-list-modal-<%= cost_list.id %>"
     tabindex="-1"
     aria-labelledby="rename-cost-list-modal-label-<%= cost_list.id %>"
     aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <%= form_with model: cost_list,
                    url: update_title_cost_list_path(cost_list),
                    method: :patch do |f| %>
        <div class="modal-header">
          <h2 class="modal-title fs-5" id="rename-cost-list-modal-label-<%= cost_list.id %>">
            リスト名を変更
          </h2>
          <button type="button"
                  class="btn-close"
                  data-bs-dismiss="modal"
                  aria-label="閉じる"></button>
        </div>

        <div class="modal-body">
          <%= f.label :title, "リスト名", class: "form-label" %>
          <%= f.text_field :title, class: "form-control", maxlength: 50 %>
        </div>

        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">キャンセル</button>
          <%= f.submit "変更する", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
