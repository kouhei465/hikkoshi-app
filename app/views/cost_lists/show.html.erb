<main class="container py-5">
  <h2 class="mb-4">費用詳細</h2>

  <%= render "cost_summary",cost_list: @cost_list,total_amount: @total_amount,budget_amount: @budget_amount,difference: @difference,editable_status: true %>

  <div class="bg-light p-4 mb-4">
    <h5>判断メモ</h5>

    <% if @cost_list.memo.present? %>
      <p><%= simple_format(@cost_list.memo) %></p>
    <% else %>
      <p class="text-muted mb-0">メモはまだありません</p>
    <% end %>
  </div>

  <div class="d-flex gap-3">
    <%= link_to "マイページに戻る", mypage_path, class: "btn btn-secondary" %>
    <%= link_to "計算をやり直す", new_cost_list_path, class: "btn btn-primary" %>
  </div>
</main>