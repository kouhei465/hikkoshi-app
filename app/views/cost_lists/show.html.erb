<main class="container py-5">
  <h2 class="mb-4">費用詳細</h2>

  <%= render "cost_summary",
             cost_list: @cost_list,
             total_amount: @total_amount,
             budget_amount: @budget_amount,
             difference: @difference,
             category_totals: @category_totals,
             largest_category: @largest_category,
             editable_status: true %>

  <div class="bg-light p-4 mb-4">
    <h5>判断メモ</h5>

    <%= form_with model: @cost_list,
                  url: update_memo_cost_list_path(@cost_list),
                  method: :patch,
                  data: { turbo: false } do |f| %>
      <div class="mb-3">
        <%= f.text_area :memo,
                        class: "form-control",
                        rows: 4,
                        placeholder: "例：この内容で進める" %>
      </div>

      <%= f.submit "判断メモを保存する", class: "btn btn-primary" %>
    <% end %>
  </div>

  <div class="d-flex gap-3">
    <%= link_to "マイページに戻る", mypage_path, class: "btn btn-secondary" %>
    <%= link_to "費用を編集する", edit_cost_list_path(@cost_list), class: "btn btn-primary" %>
  </div>
</main>
