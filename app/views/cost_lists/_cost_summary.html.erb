<div class="bg-light p-4 mb-4">
  <h5>費用内訳</h5>

  <% cost_list.cost_items.each do |item| %>
    <div class="d-flex justify-content-between border-bottom py-2">
      <div>
        <strong><%= item.name %></strong>

        <% if editable_status && cost_list.persisted? %>
          <%= form_with model: item,
                        url: update_status_cost_list_cost_item_path(cost_list, item),
                        method: :patch,
                        local: true,
                        class: "d-inline-flex align-items-center gap-2 ms-2" do |f| %>
            <%= f.select :status,
                         CostItem.statuses.keys.map { |status| [t("enums.cost_item.status.#{status}"), status] },
                         {},
                         class: "form-select form-select-sm" %>

            <%= f.submit "更新", class: "btn btn-sm btn-outline-primary" %>
          <% end %>
        <% else %>
          <span class="ms-2">
            <%= t("enums.cost_item.status.#{item.status}") %>
          </span>
        <% end %>
      </div>

      <div>
        <%= number_to_currency(item.amount.to_i, unit: "円", precision: 0, format: "%n%u") %>
      </div>
    </div>
  <% end %>

  <div class="mt-4">
    <h5>ステータス別確認</h5>

    <% CostItem.statuses.keys.each do |status| %>
      <% items = cost_list.cost_items.select { |item| item.status == status } %>

      <div class="mb-3">
        <h6><%= t("enums.cost_item.status.#{status}") %></h6>

        <% if items.present? %>
          <ul class="mb-0">
            <% items.each do |item| %>
              <li>
                <%= item.name %>（<%= number_to_currency(item.amount.to_i, unit: "円", precision: 0, format: "%n%u") %>）
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted mb-0">該当する項目はありません</p>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
