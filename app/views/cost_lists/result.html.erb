<main class="container py-5">
  <h2 class="mb-4">計算結果</h2>

  <%= render "cost_summary",cost_list: @cost_list,total_amount: @total_amount,budget_amount: @budget_amount,difference: @difference,editable_status: false %>

  <div class="bg-light p-4 mb-4">
    <h5>判断メモ</h5>
    <p class="text-muted mb-0">保存後に詳細画面からメモを編集できます</p>
  </div>

  <div class="d-flex gap-3">
    <% if logged_in? %>
      <%= button_to "内容を保存する",save_session_cost_lists_path,method: :post,data: { turbo: false },class: "btn btn-primary" %>
    <% else %>
      <%= link_to "ログインして内容を保存する", login_path, class: "btn btn-primary" %>
    <% end %>

    <%= link_to "もう一度計算する", new_cost_list_path, class: "btn btn-primary" %>
  </div>
</main>