<main class="container py-5">
  <h2 class="mb-4">計算結果</h2>

  <%= render "cost_summary",cost_list: @cost_list,total_amount: @total_amount,budget_amount: @budget_amount,difference: @difference,editable_status: false %>

  <%= form_with model: @cost_list,
                url: save_session_cost_lists_path,
                method: :post,
                data: { turbo: false } do |f| %>
    <div class="bg-light p-4 mb-4">
      <h5>判断メモ</h5>

      <div class="mb-3">
        <%= f.text_area :memo,
                        class: "form-control",
                        rows: 4,
                        placeholder: "例：この内容で進める " %>
      </div>
    </div>

    <div class="d-flex gap-3">
      <% if logged_in? %>
        <%= f.submit "内容を保存する", class: "btn btn-primary" %>
      <% else %>
        <%= f.submit "ログインして内容を保存する", class: "btn btn-primary" %>
      <% end %>

      <%= link_to "もう一度計算する", new_cost_list_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</main>
