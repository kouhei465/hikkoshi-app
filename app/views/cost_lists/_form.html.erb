<%= form_with model: cost_list,
              data: {
                turbo: false,
                controller: "nested-form",
                nested_form_estimate_amounts_by_name_value: CostItem::REFERENCE_ESTIMATE_AMOUNTS_BY_NAME.to_json
              } do |f| %>
  <% if cost_list.persisted? %>
    <div class="mb-3">
      <%= f.label :title, "リスト名" %>
      <%= f.text_field :title,
                       class: "form-control",
                       maxlength: 50,
                       required: true %>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :budget, "予算" %>
    <%= f.number_field :budget, class: "form-control" %>
  </div>

  <%# 費用項目をカテゴリごとに入力できるように表示 %>
  <% CostItem.categories.keys.each do |category| %>
    <% category_items = cost_list.cost_items.select { |item| item.category == category } %>
    <% new_item = CostItem.new(category: category, status: :unchecked) %>
    <% estimate_text = CostItem::REFERENCE_ESTIMATES[category] %>

    <section class="mb-4">
      <h5><%= t("enums.cost_item.category.#{category}") %></h5>

      <datalist id="cost-item-name-options-<%= category %>">
        <% CostItem.name_options_for(category).each do |name| %>
          <option value="<%= name %>"></option>
        <% end %>
      </datalist>

      <div data-nested-form-target="container" data-category="<%= category %>">
        <% category_items.each do |cost_item| %>
          <%= f.fields_for :cost_items, cost_item do |item_form| %>
            <%= render "cost_item_fields",
                       item_form: item_form,
                       show_estimate: show_estimate,
                       estimate_text: estimate_text %>
          <% end %>
        <% end %>
      </div>

      <template data-nested-form-target="template" data-category="<%= category %>">
        <%= f.fields_for :cost_items, new_item, child_index: "NEW_RECORD_#{category}" do |item_form| %>
          <%= render "cost_item_fields",
                     item_form: item_form,
                     show_estimate: show_estimate,
                     estimate_text: estimate_text %>
        <% end %>
      </template>

      <div class="d-grid d-sm-block">
        <%= button_tag "+ #{t("enums.cost_item.category.#{category}")}を追加",
                       type: "button",
                       class: "btn btn-outline-primary btn-sm",
                       data: { action: "nested-form#add", nested_form_category_param: category } %>
      </div>
    </section>
  <% end %>

  <div class="row justify-content-center">
    <div class="col-12 col-sm-auto">
      <%= f.submit submit_label, class: "btn btn-primary w-100" %>
    </div>
  </div>
<% end %>
