<header class="bg-light d-flex flex-column flex-sm-row flex-wrap justify-content-between align-items-start align-items-sm-center gap-3 px-3 px-md-5 py-3 py-md-4">
  <%= link_to "引っ越し費用まとめ帳", root_path, class: "fw-bold fs-5 text-dark text-decoration-none text-break lh-sm" %>

  <nav class="d-flex flex-wrap gap-2 gap-sm-4 align-items-center align-self-stretch align-self-sm-auto">
    <%# ログイン状態に応じてヘッダーのリンクを切り替える %>
    <% if logged_in? %>
      <%= link_to current_user.name, mypage_path, class: "text-dark text-decoration-none text-break lh-sm" %>
      <%= button_to "ログアウト", logout_path, method: :delete, class: "btn btn-link p-0 text-dark text-decoration-none" %>
    <% else %>
      <%= link_to "新規登録", new_user_path, class: "text-dark text-decoration-none" %>
      <%= link_to "ログイン", login_path, class: "text-dark text-decoration-none" %>
    <% end %>
  </nav>
</header>
